<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="livros_por_autor" pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <field name="autorNome" class="java.lang.String"/>
    <field name="livroCodigo" class="java.lang.Integer"/>
    <field name="titulo" class="java.lang.String"/>
    <field name="editora" class="java.lang.String"/>
    <field name="edicao" class="java.lang.Integer"/>
    <field name="anoPublicacao" class="java.lang.String"/>
    <field name="valor" class="java.math.BigDecimal"/>
    <field name="assuntos" class="java.lang.String"/>

    <variable name="qtdLivrosAutor" class="java.lang.Integer" resetType="Group" resetGroup="Autor" calculation="Count">
        <variableExpression><![CDATA[$F{livroCodigo}]]></variableExpression>
    </variable>
    <variable name="valorTotalAutor" class="java.math.BigDecimal" resetType="Group" resetGroup="Autor" calculation="Sum">
        <variableExpression><![CDATA[$F{valor}]]></variableExpression>
    </variable>
    <variable name="valorTotalGeral" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{valor}]]></variableExpression>
    </variable>

    <group name="Autor">
        <groupExpression><![CDATA[$F{autorNome}]]></groupExpression>
        <groupHeader>
            <band height="28">
                <rectangle>
                    <reportElement x="0" y="4" width="555" height="22" backcolor="#E9ECEF" mode="Opaque"/>
                    <graphicElement>
                        <pen lineWidth="0.0"/>
                    </graphicElement>
                </rectangle>
                <staticText>
                    <reportElement x="6" y="7" width="60" height="16"/>
                    <textElement><font size="11" isBold="true"/></textElement>
                    <text><![CDATA[Autor:]]></text>
                </staticText>
                <textField>
                    <reportElement x="66" y="7" width="489" height="16"/>
                    <textElement><font size="11" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$F{autorNome}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="22">
                <textField>
                    <reportElement x="0" y="2" width="375" height="16"/>
                    <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA["Livros do autor: " + $V{qtdLivrosAutor} + "   |   Total: "]]></textFieldExpression>
                </textField>
                <textField pattern="¤ #,##0.00">
                    <reportElement x="375" y="2" width="180" height="16"/>
                    <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$V{valorTotalAutor}]]></textFieldExpression>
                </textField>
                <line>
                    <reportElement x="0" y="20" width="555" height="1"/>
                </line>
            </band>
        </groupFooter>
    </group>

    <title>
        <band height="40">
            <staticText>
                <reportElement x="0" y="0" width="555" height="24"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[Relatório de Livros por Autor]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="555" height="12"/>
                <textElement textAlignment="Center"><font size="8"/></textElement>
                <textFieldExpression><![CDATA["Emitido em " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="18">
            <staticText>
                <reportElement x="0" y="0" width="150" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Título]]></text>
            </staticText>
            <staticText>
                <reportElement x="150" y="0" width="95" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Editora]]></text>
            </staticText>
            <staticText>
                <reportElement x="245" y="0" width="40" height="16"/>
                <textElement textAlignment="Center"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Ed.]]></text>
            </staticText>
            <staticText>
                <reportElement x="285" y="0" width="40" height="16"/>
                <textElement textAlignment="Center"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Ano]]></text>
            </staticText>
            <staticText>
                <reportElement x="325" y="0" width="140" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Assuntos]]></text>
            </staticText>
            <staticText>
                <reportElement x="465" y="0" width="90" height="16"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Valor]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="16">
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="0" width="150" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{titulo}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="150" y="0" width="95" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{editora}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="245" y="0" width="40" height="14"/>
                <textElement textAlignment="Center"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{edicao}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="285" y="0" width="40" height="14"/>
                <textElement textAlignment="Center"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{anoPublicacao}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="325" y="0" width="140" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{assuntos}]]></textFieldExpression>
            </textField>
            <textField pattern="¤ #,##0.00">
                <reportElement x="465" y="0" width="90" height="14"/>
                <textElement textAlignment="Right"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{valor}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="26">
            <line>
                <reportElement x="0" y="2" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="0" y="6" width="375" height="16"/>
                <textElement textAlignment="Right"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Valor total geral:]]></text>
            </staticText>
            <textField pattern="¤ #,##0.00">
                <reportElement x="375" y="6" width="180" height="16"/>
                <textElement textAlignment="Right"><font size="10" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{valorTotalGeral}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
